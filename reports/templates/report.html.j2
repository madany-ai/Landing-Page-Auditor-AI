<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landing Page Audit — {{ url }}</title>
  <style>
    /* ── Reset & Root ───────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:          #0a0b0f;
      --surface:     #13151d;
      --surface-2:   #1a1d2e;
      --border:      #1e2235;
      --accent:      #7c3aed;
      --accent-2:    #8b5cf6;
      --success:     #10b981;
      --warning:     #f59e0b;
      --error:       #ef4444;
      --text:        #e2e8f0;
      --text-dim:    #94a3b8;
      --text-muted:  #475569;
      --radius:      16px;
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Segoe UI', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 15px;
      line-height: 1.65;
    }
    a { color: var(--accent-2); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ── Layout ─────────────────────────────────────────────────────────── */
    .container { max-width: 1080px; margin: 0 auto; padding: 0 24px 80px; }

    /* ── Header ─────────────────────────────────────────────────────────── */
    header {
      background: linear-gradient(160deg, #0d0f1a 0%, #13151d 60%, #0d1020 100%);
      border-bottom: 1px solid var(--border);
      padding: 56px 24px 48px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    header::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(124,58,237,.18), transparent);
      pointer-events: none;
    }
    .header-logo {
      font-size: 13px; font-weight: 600; letter-spacing: 2px;
      text-transform: uppercase; color: var(--accent-2);
      margin-bottom: 20px; display: block;
    }
    header h1 {
      font-size: clamp(28px, 5vw, 44px); font-weight: 800;
      background: linear-gradient(135deg, #e2e8f0 30%, var(--accent-2));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; margin-bottom: 12px;
    }
    .audit-url {
      font-size: 14px; color: var(--text-dim);
      word-break: break-all; margin-bottom: 6px;
    }
    .audit-date { font-size: 12px; color: var(--text-muted); }

    /* ── Score Section ──────────────────────────────────────────────────── */
    .score-section {
      display: flex; align-items: center; justify-content: center;
      gap: 48px; flex-wrap: wrap;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 40px 32px; margin: 40px 0 28px;
    }
    .gauge-wrap { text-align: center; }
    .gauge-label {
      margin-top: 8px;
      font-size: 13px; color: var(--text-dim); font-weight: 500;
    }
    .score-meta { text-align: center; }
    .score-grade {
      font-size: 72px; font-weight: 900; line-height: 1;
      color: {{ score_color }};
    }
    .score-label-text {
      font-size: 20px; font-weight: 600; color: var(--text);
      margin-top: 6px;
    }
    .score-tagline { font-size: 13px; color: var(--text-dim); margin-top: 4px; }

    /* ── Cards ──────────────────────────────────────────────────────────── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px 32px;
      margin-bottom: 24px;
    }
    .card-title {
      font-size: 18px; font-weight: 700; margin-bottom: 18px;
      display: flex; align-items: center; gap: 10px;
    }
    .card-title .icon { font-size: 22px; }

    /* ── Overview Grid ──────────────────────────────────────────────────── */
    .overview-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 14px; margin-bottom: 24px;
    }
    .overview-item {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 12px; padding: 16px 18px;
    }
    .overview-item-name { font-size: 12px; color: var(--text-dim); font-weight: 500; margin-bottom: 6px; }
    .overview-item-score { font-size: 22px; font-weight: 800; }
    .overview-mini-bar { height: 4px; background: var(--border); border-radius: 2px; margin-top: 8px; overflow: hidden; }
    .overview-mini-fill { height: 100%; border-radius: 2px; transition: width .6s ease; }

    /* ── Revenue Leaks ──────────────────────────────────────────────────── */
    .leaks-card {
      background: rgba(239,68,68,.05);
      border: 1px solid rgba(239,68,68,.25);
      border-radius: var(--radius); padding: 28px 32px; margin-bottom: 24px;
    }
    .leak-item {
      display: flex; gap: 14px; align-items: flex-start;
      padding: 12px 0; border-bottom: 1px solid rgba(239,68,68,.1);
    }
    .leak-item:last-child { border-bottom: none; }
    .leak-num {
      min-width: 28px; height: 28px;
      background: rgba(239,68,68,.2); color: #ef4444;
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 800; flex-shrink: 0;
    }
    .leak-text { font-size: 14px; color: var(--text); line-height: 1.5; }

    /* ── Strengths / Weaknesses ─────────────────────────────────────────── */
    .sw-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
    @media (max-width: 640px) { .sw-grid { grid-template-columns: 1fr; } }
    .sw-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px 28px; }
    .sw-item { padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 14px; }
    .sw-item:last-child { border-bottom: none; }
    .sw-item::before { margin-right: 8px; }
    .strengths-card .sw-item::before { content: '✅'; }
    .weaknesses-card .sw-item::before { content: '⚠️'; }

    /* ── Category Cards ─────────────────────────────────────────────────── */
    .category-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius); padding: 28px 32px; margin-bottom: 20px;
      position: relative; overflow: hidden;
    }
    .category-card::before {
      content: ''; position: absolute; top: 0; left: 0;
      width: 4px; height: 100%; border-radius: 4px 0 0 4px;
    }
    .cat-header {
      display: flex; align-items: center; gap: 14px; margin-bottom: 14px; flex-wrap: wrap;
    }
    .cat-name { font-size: 18px; font-weight: 700; flex: 1; }
    .cat-score-badge {
      font-size: 15px; font-weight: 800; padding: 4px 14px;
      border-radius: 20px; border: 2px solid;
    }
    .weight-chip {
      font-size: 11px; color: var(--text-muted); background: var(--surface-2);
      border: 1px solid var(--border); border-radius: 12px; padding: 2px 10px;
    }
    .progress-track {
      height: 8px; background: var(--border); border-radius: 4px;
      margin-bottom: 20px; overflow: hidden;
    }
    .progress-fill { height: 100%; border-radius: 4px; }
    .cat-body { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    @media (max-width: 640px) { .cat-body { grid-template-columns: 1fr; } }
    .cat-section-title {
      font-size: 12px; font-weight: 700; letter-spacing: 1px;
      text-transform: uppercase; color: var(--text-dim); margin-bottom: 10px;
    }
    .finding-item, .rec-item {
      font-size: 13px; line-height: 1.55;
      padding: 8px 0; border-bottom: 1px solid var(--border);
    }
    .finding-item:last-child, .rec-item:last-child { border-bottom: none; }
    .rec-item::before { content: '💡 '; }

    /* ── Action Plan ────────────────────────────────────────────────────── */
    .action-priority-title {
      font-size: 15px; font-weight: 700; margin: 24px 0 12px;
      display: flex; align-items: center; gap: 8px;
    }
    .action-group { margin-bottom: 16px; }
    .action-group-name { font-size: 13px; font-weight: 600; color: var(--text-dim); margin-bottom: 6px; }
    .action-item {
      font-size: 13px; padding: 10px 14px; border-radius: 8px;
      margin-bottom: 6px; border-left: 3px solid;
    }
    .action-high { background: rgba(239,68,68,.07); border-color: #ef4444; }
    .action-med  { background: rgba(245,158,11,.07); border-color: #f59e0b; }
    .action-low  { background: rgba(16,185,129,.07); border-color: #10b981; }

    /* ── Executive Summary ──────────────────────────────────────────────── */
    .exec-summary { font-size: 15px; line-height: 1.75; color: var(--text); }

    /* ── Footer ─────────────────────────────────────────────────────────── */
    footer {
      text-align: center; padding: 32px 0 0;
      border-top: 1px solid var(--border);
      font-size: 12px; color: var(--text-muted);
    }
    footer strong { color: var(--accent-2); }

    /* ── Section headings ───────────────────────────────────────────────── */
    .section-heading {
      font-size: 22px; font-weight: 800; margin: 40px 0 20px;
      display: flex; align-items: center; gap: 10px;
    }
  </style>
</head>
<body>

<!-- ═══════════════════════ HEADER ═══════════════════════ -->
<header>
  <span class="header-logo">🚀 Landing Page Auditor AI</span>
  <h1>Conversion Rate Audit Report</h1>
  <p class="audit-url"><a href="{{ url }}" target="_blank" rel="noopener">{{ url }}</a></p>
  <p class="audit-date">Generated {{ timestamp }}</p>
</header>

<div class="container">

  <!-- ════════════ SCORE ════════════ -->
  <div class="score-section">
    <div class="gauge-wrap">
      <!-- SVG semicircle gauge — radius=90, arc from left→top→right -->
      <svg viewBox="0 0 200 110" width="240" height="132" role="img" aria-label="Score gauge">
        <!-- Background arc -->
        <path d="M 10,100 A 90,90 0 0,1 190,100"
              fill="none" stroke="#1e2235" stroke-width="16" stroke-linecap="round"/>
        <!-- Score fill arc -->
        <path d="M 10,100 A 90,90 0 0,1 190,100"
              fill="none" stroke="{{ score_color }}" stroke-width="16" stroke-linecap="round"
              stroke-dasharray="{{ score_dash }} {{ arc_length }}"/>
        <!-- Score number -->
        <text x="100" y="82" text-anchor="middle" dominant-baseline="middle"
              fill="{{ score_color }}" font-family="Segoe UI, system-ui, sans-serif"
              font-size="40" font-weight="800">{{ result.overall_score | int }}</text>
        <text x="100" y="100" text-anchor="middle" dominant-baseline="middle"
              fill="#94a3b8" font-family="Segoe UI, system-ui, sans-serif" font-size="13">
          out of 100
        </text>
      </svg>
      <div class="gauge-label">CRO Score</div>
    </div>

    <div class="score-meta">
      <div class="score-grade" style="color:{{ score_color }};">{{ score_grade }}</div>
      <div class="score-label-text">{{ score_label }}</div>
      <div class="score-tagline">Conversion Effectiveness Rating</div>
    </div>
  </div>

  <!-- ════════════ EXECUTIVE SUMMARY ════════════ -->
  <div class="card">
    <div class="card-title"><span class="icon">📋</span> Executive Summary</div>
    <p class="exec-summary">{{ result.executive_summary }}</p>
  </div>

  <!-- ════════════ OVERVIEW GRID ════════════ -->
  <div class="section-heading">📊 Category Breakdown</div>
  <div class="overview-grid">
  {% for name, analysis, weight in categories %}
    {% set pct = (analysis.score / 10 * 100) | int %}
    {% set color = category_color(analysis.score) %}
    <div class="overview-item">
      <div class="overview-item-name">{{ name }} · {{ weight }}%</div>
      <div class="overview-item-score" style="color:{{ color }};">{{ analysis.score }}/10</div>
      <div class="overview-mini-bar">
        <div class="overview-mini-fill" style="width:{{ pct }}%; background:{{ color }};"></div>
      </div>
    </div>
  {% endfor %}
  </div>

  <!-- ════════════ REVENUE LEAKS ════════════ -->
  <div class="section-heading">🚨 Top Revenue Leaks</div>
  <div class="leaks-card">
    {% for leak in result.top_revenue_leaks %}
    <div class="leak-item">
      <div class="leak-num">{{ loop.index }}</div>
      <div class="leak-text">{{ leak }}</div>
    </div>
    {% else %}
    <p style="color:var(--text-dim);">No revenue leaks identified.</p>
    {% endfor %}
  </div>

  <!-- ════════════ STRENGTHS & WEAKNESSES ════════════ -->
  <div class="sw-grid">
    <div class="sw-card strengths-card">
      <div class="card-title"><span class="icon">💪</span> Strengths</div>
      {% for s in result.strengths %}
      <div class="sw-item">{{ s }}</div>
      {% else %}
      <div class="sw-item" style="color:var(--text-muted);">None identified</div>
      {% endfor %}
    </div>
    <div class="sw-card weaknesses-card">
      <div class="card-title"><span class="icon">⚠️</span> Critical Weaknesses</div>
      {% for w in result.weaknesses %}
      <div class="sw-item">{{ w }}</div>
      {% else %}
      <div class="sw-item" style="color:var(--text-muted);">None identified</div>
      {% endfor %}
    </div>
  </div>

  <!-- ════════════ DETAILED CATEGORY ANALYSIS ════════════ -->
  <div class="section-heading">🔍 Detailed Analysis</div>

  {% for name, analysis, weight in categories %}
  {% set color = category_color(analysis.score) %}
  {% set pct = (analysis.score / 10 * 100) | int %}
  <div class="category-card" style="--accent-color:{{ color }};">
    <style>.category-card:nth-child({{ loop.index }})::before { background: {{ color }}; }</style>

    <div class="cat-header">
      <span class="cat-name">{{ name }}</span>
      <span class="cat-score-badge" style="color:{{ color }}; border-color:{{ color }};">
        {{ analysis.score }}/10
      </span>
      <span class="weight-chip">Weight: {{ weight }}%</span>
    </div>

    <div class="progress-track">
      <div class="progress-fill" style="width:{{ pct }}%; background:{{ color }};"></div>
    </div>

    <div class="cat-body">
      <div>
        <div class="cat-section-title">Findings</div>
        {% for finding in analysis.findings %}
        <div class="finding-item">{{ finding }}</div>
        {% else %}
        <div class="finding-item" style="color:var(--text-muted);">No findings recorded.</div>
        {% endfor %}
      </div>
      <div>
        <div class="cat-section-title">Recommendations</div>
        {% for rec in analysis.recommendations %}
        <div class="rec-item">{{ rec }}</div>
        {% else %}
        <div class="rec-item" style="color:var(--text-muted);">No recommendations recorded.</div>
        {% endfor %}
      </div>
    </div>
  </div>
  {% endfor %}

  <!-- ════════════ ACTION PLAN ════════════ -->
  <div class="card" style="margin-top:40px;">
    <div class="card-title"><span class="icon">🎯</span> Prioritised Action Plan</div>

    <div class="action-priority-title">🔴 High Priority (Score &lt; 5)</div>
    {% set ns = namespace(found=false) %}
    {% for name, analysis, weight in categories %}{% if analysis.score < 5 %}{% set ns.found = true %}
    <div class="action-group">
      <div class="action-group-name">{{ name }}</div>
      {% for rec in analysis.recommendations %}
      <div class="action-item action-high">{{ rec }}</div>
      {% endfor %}
    </div>
    {% endif %}{% endfor %}
    {% if not ns.found %}<p style="color:var(--text-muted);font-size:13px;margin-bottom:12px;">No high-priority issues.</p>{% endif %}

    <div class="action-priority-title">🟡 Medium Priority (Score 5–7)</div>
    {% set ns2 = namespace(found=false) %}
    {% for name, analysis, weight in categories %}{% if analysis.score >= 5 and analysis.score <= 7 %}{% set ns2.found = true %}
    <div class="action-group">
      <div class="action-group-name">{{ name }}</div>
      {% for rec in analysis.recommendations %}
      <div class="action-item action-med">{{ rec }}</div>
      {% endfor %}
    </div>
    {% endif %}{% endfor %}
    {% if not ns2.found %}<p style="color:var(--text-muted);font-size:13px;margin-bottom:12px;">No medium-priority issues.</p>{% endif %}

    <div class="action-priority-title">🟢 Low Priority (Score &gt; 7)</div>
    {% set ns3 = namespace(found=false) %}
    {% for name, analysis, weight in categories %}{% if analysis.score > 7 %}{% set ns3.found = true %}
    <div class="action-group">
      <div class="action-group-name">{{ name }}</div>
      {% for rec in analysis.recommendations %}
      <div class="action-item action-low">{{ rec }}</div>
      {% endfor %}
    </div>
    {% endif %}{% endfor %}
    {% if not ns3.found %}<p style="color:var(--text-muted);font-size:13px;">No low-priority issues.</p>{% endif %}
  </div>

  {% if comparison %}
  <!-- ════════════ COMPETITOR DISCOVERY INTELLIGENCE ════════════ -->
  <div class="section-heading">🤖 Competitor Discovery Intelligence</div>
  <div class="card" style="margin-bottom:40px;">
    <div style="display: flex; gap: 24px; margin-bottom: 24px;">
      <div>
        <div style="font-size: 12px; color: var(--text-dim); text-transform: uppercase; font-weight: 700;">Discovery Quality Score</div>
        <div style="font-size: 24px; font-weight: 800; color: var(--accent-1);">{{ comparison.discovery_metrics.quality_score }} / 100</div>
      </div>
      <div>
        <div style="font-size: 12px; color: var(--text-dim); text-transform: uppercase; font-weight: 700;">Total Evaluated</div>
        <div style="font-size: 24px; font-weight: 800; color: var(--text);">{{ comparison.discovery_metrics.total_evaluated }}</div>
      </div>
    </div>
    
    <div class="cat-section-title">✅ Valid Competitors Identified</div>
    <div style="overflow-x: auto; margin-bottom: 24px;">
      <table style="width:100%; border-collapse:collapse; text-align:left; font-size: 13px;">
        <thead>
          <tr style="background:var(--surface-2); border-bottom:1px solid var(--border);">
            <th style="padding:12px;">Domain</th>
            <th style="padding:12px;">Confidence</th>
            <th style="padding:12px;">Reason Selected</th>
          </tr>
        </thead>
        <tbody>
          {% for comp in comparison.competitors %}
          <tr style="border-bottom:1px solid var(--border);">
            <td style="padding:12px;"><a href="{{ comp.url }}" target="_blank" style="color:var(--accent-2);">{{ comp.domain }}</a></td>
            <td style="padding:12px; font-weight: 600;">{{ comp.confidence }}%</td>
            <td style="padding:12px; color:var(--text-muted);">{{ comp.selection_reason }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="cat-section-title">❌ Rejected Candidates Log</div>
    <div style="overflow-x: auto;">
      <table style="width:100%; border-collapse:collapse; text-align:left; font-size: 13px;">
        <thead>
          <tr style="background:var(--surface-2); border-bottom:1px solid var(--border);">
            <th style="padding:12px;">Domain</th>
            <th style="padding:12px;">Confidence</th>
            <th style="padding:12px;">Rejection Reason</th>
          </tr>
        </thead>
        <tbody>
          {% for rej in comparison.rejected_candidates %}
          <tr style="border-bottom:1px solid var(--border);">
            <td style="padding:12px; color:var(--text-dim);">{{ rej.domain }}</td>
            <td style="padding:12px; font-weight: 600; color:var(--accent-1);">{{ rej.confidence }}%</td>
            <td style="padding:12px; color:var(--text-muted);">{{ rej.reason }}</td>
          </tr>
          {% else %}
          <tr><td colspan="3" style="padding: 12px; color: var(--text-muted);">No candidates were rejected.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <!-- ════════════ COMPETITOR BENCHMARK ════════════ -->
  <div class="section-heading">⚔️ Competitor Benchmark</div>
  <div class="card" style="padding:0; overflow:auto;">
    <table style="width:100%; border-collapse:collapse; text-align:left;">
      <thead>
        <tr style="background:var(--surface-2); border-bottom:1px solid var(--border);">
          <th style="padding:16px;">Category</th>
          <th style="padding:16px;">Your Score</th>
          <th style="padding:16px;">Competitor Avg</th>
          <th style="padding:16px;">Gap</th>
        </tr>
      </thead>
      <tbody>
        {% set rows = [
            ("Clarity", comparison.benchmarks.clarity),
            ("Value Prop", comparison.benchmarks.value_proposition),
            ("Offer", comparison.benchmarks.offer),
            ("Trust", comparison.benchmarks.trust),
            ("CTA", comparison.benchmarks.cta),
            ("ICP", comparison.benchmarks.icp),
            ("Objections", comparison.benchmarks.objections),
            ("Friction", comparison.benchmarks.friction),
        ] %}
        {% for name, b in rows %}
        <tr style="border-bottom:1px solid var(--border);">
          <td style="padding:16px; font-weight:600;">{{ name }}</td>
          <td style="padding:16px;">{{ b.target_score }}</td>
          <td style="padding:16px; color:var(--text-muted);">{{ b.competitor_average }}</td>
          <td style="padding:16px; color: {% if b.gap >= 0 %}var(--accent-2){% else %}var(--accent-1){% endif %}; font-weight:700;">
            {% if b.gap >= 0 %}+{% endif %}{{ b.gap }}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="section-heading">💡 Competitive Intelligence</div>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-bottom:40px;">
    <div class="card weaknesses-card">
      <div class="card-title">🔻 Missing Elements</div>
      {% for me in comparison.insights.missing_elements %}
      <div class="sw-item">{{ me }}</div>
      {% endfor %}
    </div>
    <div class="card strengths-card">
      <div class="card-title">💪 Your Advantages</div>
      {% for adv in comparison.insights.competitive_advantages %}
      <div class="sw-item">{{ adv }}</div>
      {% endfor %}
    </div>
  </div>

  <div class="section-heading">🚀 Strategic Insights</div>
  {% for ins in comparison.insights.deep_insights %}
  <div class="card" style="margin-bottom:20px;">
    <h3 style="margin-top:0; color:var(--text); font-size:16px; margin-bottom:12px;">{{ ins.observation }}</h3>
    <div class="finding-item" style="border:none; padding:4px 0;"><strong>Evidence:</strong> {{ ins.evidence }}</div>
    <div class="finding-item" style="border:none; padding:4px 0;"><strong style="color:var(--accent-2);">Business Impact:</strong> {{ ins.impact }}</div>
    <div class="rec-item" style="border:none; margin-top:8px;"><strong>Recommendation:</strong> {{ ins.recommendation }}</div>
  </div>
  {% endfor %}

  <div class="section-heading">🎯 Prioritized Action Plan</div>
  <div class="card" style="padding:0; overflow:auto;">
    <table style="width:100%; border-collapse:collapse; text-align:left;">
      <thead>
        <tr style="background:var(--surface-2); border-bottom:1px solid var(--border);">
          <th style="padding:16px; width:80px;">Priority</th>
          <th style="padding:16px;">Action</th>
          <th style="padding:16px; width:120px;">Impact</th>
          <th style="padding:16px; width:120px;">Effort</th>
          <th style="padding:16px;">Description</th>
        </tr>
      </thead>
      <tbody>
        {% for action in comparison.insights.action_plan|sort(attribute='priority') %}
        <tr style="border-bottom:1px solid var(--border);">
          <td style="padding:16px; font-weight:700; text-align:center;">
            <span style="background:var(--surface); padding:6px 12px; border-radius:12px; border:1px solid var(--border);">{{ action.priority }}</span>
          </td>
          <td style="padding:16px; font-weight:600;">{{ action.title }}</td>
          <td style="padding:16px; color:var(--text-muted);">{{ action.expected_impact }}</td>
          <td style="padding:16px; color:var(--text-muted);">{{ action.effort }}</td>
          <td style="padding:16px; font-size:13px; line-height:1.5; color:var(--text-dim);">{{ action.description }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}

</div><!-- /.container -->

<footer>
  <p>Generated by <strong>Landing Page Auditor AI</strong> · {{ timestamp }}</p>
</footer>

</body>
</html>
